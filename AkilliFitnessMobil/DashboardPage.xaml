<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AkilliFitnessMobil.DashboardPage"
             BackgroundColor="#1E1E1E"
             Title="Ana Sayfa">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Kişisel Özet" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#00E676" />

            <Frame BackgroundColor="#333333" CornerRadius="10" Padding="15">
                <VerticalStackLayout>
                    <Label Text="Günlük Hedefler" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,0,0,10" />
                    <Label Text="Alınan Kalori: 1500 / 2500" TextColor="LightGray" />
                    <Label Text="Su Tüketimi: 1.5L / 3.0L" TextColor="LightGray" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Çıkış Yap" 
                    Clicked="OnLogoutClicked" 
                    BackgroundColor="Red" 
                    TextColor="White" 
                    FontAttributes="Bold"
                    Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>